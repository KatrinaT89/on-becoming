# EmailOctopus — newsletter signups
# Get your API key at emailoctopus.com → Settings → API
EMAILOCTOPUS_API_KEY=your_emailoctopus_api_key_here

# The ID of the mailing list to add subscribers to
# Find it at emailoctopus.com → Lists → your list → Settings
EMAILOCTOPUS_LIST_ID=your_list_id_here

# Resend — contact form emails
# Get your API key at resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here

# The email address that receives contact form submissions (Katrina's inbox)
CONTACT_TO_EMAIL=katrina@example.com

# A verified sender address on your Resend domain
# e.g. "On Becoming <hello@onbecoming.com>"
CONTACT_FROM_EMAIL=hello@yourdomain.com
